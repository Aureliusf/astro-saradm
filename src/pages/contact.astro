---
export const prerender = true;

import type { SanityDocument } from "@sanity/client";
import { sanityClient } from "sanity:client";
import imageUrlBuilder from '@sanity/image-url';
import type { SanityImageSource } from "@sanity/image-url/lib/types/types";
import { PortableText } from "astro-portabletext";

import MainLayout from '../layouts/main.astro';
import Footer from '../components/Footer.astro';

const builder = imageUrlBuilder(sanityClient);

function urlFor(source: SanityImageSource) {
  return builder.image(source);
}

function generateImageProps(image: SanityImageSource, sizes: string) {
  const base = urlFor(image).quality(90).auto('format');
  return {
    src: base.width(800).url(),
    srcset: [400, 800, 1200]
      .map(w => `${base.width(w).url()} ${w}w`)
      .join(', '),
    sizes: sizes,
  };
}

const QUERY = `*[_type == "contact"][0] {
  title,
  picture,
  bottomCopy
}`;

const content = await sanityClient.fetch<SanityDocument>(QUERY);
const imageProps = content && content.picture && content.picture.image ? generateImageProps(content.picture.image, '(min-width: 512px) 512px, calc(100vw - 2rem)') : null;

import ContactForm from '../components/ContactForm.jsx';
---
<MainLayout title="Contacto">
  <main class="container mx-auto min-h-screen px-4 md:px-8 pt-2 md:pt-4 pb-4 md:pb-8 flex flex-col items-center">
    <h1>Contáctame</h1>

    <div class="flex flex-col md:flex-row items-center md:items-start gap-8 w-full max-w-3xl">
      <!-- Picture Frame (Left Column on Desktop) -->
      <div class="w-full md:w-1/2 max-w-lg mx-auto md:mx-0">
        {imageProps && <img
          src={imageProps.src}
          srcset={imageProps.srcset}
          sizes={imageProps.sizes}
          alt={content.picture?.alt || ""} 
          class="w-full aspect-auto object-cover overflow-hidden shadow-lg" 
          loading="lazy"
          decoding="async"
        />}
      </div>

      <!-- Interactive React Contact Form (Right Column on Desktop) -->
      <div class="title-font w-full md:w-1/2">
        <ContactForm client:load />
      </div>
    </div>

    <!-- Optional Bottom Copy -->
    {Array.isArray(content?.bottomCopy) && content.bottomCopy.length > 0 && (
      <div class="text-center text-xl md:text-2xl text-[#220d0c] mt-8 w-full max-w-3xl">
        <PortableText value={content.bottomCopy} />
      </div>
    )}

  </main>
</MainLayout>
<Footer />
